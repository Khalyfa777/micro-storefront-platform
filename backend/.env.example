ENVIRONMENT=development

SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters

JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30

FRONTEND_URL=http://localhost:3000
DASHBOARD_PUBLIC_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000

TRIAL_DAYS=14

PUBLIC_REGISTRATION_ENABLED=false
SELLER_INVITATION_EXPIRE_HOURS=72
SELLER_INVITATION_RATE_LIMIT_ATTEMPTS=10
SELLER_INVITATION_RATE_LIMIT_WINDOW_SECONDS=300
TRUST_PROXY_HEADERS=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/storefront_dev
REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
