# ============================
# Backend production env example
# Copy to backend/.env on production server and fill real values.
# Never commit real production secrets.
# ============================

ENVIRONMENT=production

# Security
SECRET_KEY=replace-with-a-long-random-64-character-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
TRIAL_DAYS=14

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@DB_HOST:5432/DB_NAME

# Public URLs
FRONTEND_URL=https://your-storefront-domain.com
DASHBOARD_PUBLIC_URL=https://dashboard.your-domain.com
BACKEND_PUBLIC_URL=https://api.your-domain.com

# CORS
CORS_ORIGINS=https://dashboard.your-domain.com,https://your-storefront-domain.com

# Redis
REDIS_URL=redis://REDIS_HOST:6379/0

# Upload protection and storage
MAX_REQUEST_BODY_BYTES=5242880
IMAGE_UPLOAD_MAX_BYTES=3145728
IMAGE_UPLOAD_STORE_QUOTA_BYTES=536870912
IMAGE_UPLOAD_ORPHAN_TTL_SECONDS=86400
IMAGE_UPLOAD_RATE_LIMIT_ATTEMPTS=20
IMAGE_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=300

# Paystack live keys
PAYSTACK_SECRET_KEY=replace-with-your-paystack-live-secret-key
PAYSTACK_PUBLIC_KEY=replace-with-your-paystack-live-public-key
