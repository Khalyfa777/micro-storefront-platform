* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: #f4f6fb;
  color: #111827;
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button,
input,
textarea,
select {
  font: inherit;
}

button {
  border: 0;
  cursor: pointer;
  border-radius: 12px;
  padding: 0.75rem 1rem;
  background: #111827;
  color: white;
  font-weight: 700;
}

button:hover {
  opacity: 0.9;
}

input,
textarea,
select {
  width: 100%;
  border: 1px solid #d1d5db;
  border-radius: 12px;
  padding: 0.8rem 0.9rem;
  background: white;
  color: #111827;
}

textarea {
  min-height: 90px;
  resize: vertical;
}

label {
  display: grid;
  gap: 0.4rem;
  font-weight: 700;
  color: #374151;
}

.login-page {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 1rem;
}

.login-card {
  width: min(430px, 100%);
  background: white;
  padding: 2rem;
  border-radius: 24px;
  box-shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
  display: grid;
  gap: 1rem;
}

.login-card h1 {
  margin: 0;
}

.dashboard {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 280px 1fr;
}

.sidebar {
  background: #111827;
  color: white;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.sidebar h2 {
  margin: 0;
}

.sidebar .muted {
  color: #9ca3af;
}

.store-switcher {
  display: grid;
  gap: 0.5rem;
  margin: 1rem 0;
}

.nav-btn,
.logout-btn,
.public-link {
  width: 100%;
  text-align: left;
  text-decoration: none;
  background: rgba(255, 255, 255, 0.08);
  color: white;
  padding: 0.85rem 1rem;
  border-radius: 14px;
  font-weight: 800;
}

.nav-btn.active {
  background: white;
  color: #111827;
}

.public-link {
  display: block;
  margin-top: auto;
}

.logout-btn {
  background: #dc2626;
}

.content {
  padding: 2rem;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.topbar h1 {
  margin: 0;
}

.muted {
  color: #6b7280;
}

.error-box,
.success-box {
  padding: 1rem;
  border-radius: 14px;
  margin-bottom: 1rem;
  font-weight: 700;
}

.error-box {
  background: #fee2e2;
  color: #991b1b;
}

.success-box {
  background: #dcfce7;
  color: #166534;
}

.cards {
  display: grid;
  gap: 1rem;
}

.order-card,
.product-card,
.product-form {
  background: white;
  border-radius: 22px;
  padding: 1.25rem;
  box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.card-head h3,
.product-card h3,
.product-form h2 {
  margin: 0;
}

.status,
.pill {
  display: inline-flex;
  width: fit-content;
  align-items: center;
  border-radius: 999px;
  padding: 0.4rem 0.75rem;
  font-size: 0.8rem;
  font-weight: 900;
  background: #e5e7eb;
  color: #374151;
}

.status.paid,
.active-pill {
  background: #dcfce7;
  color: #166534;
}

.status.pending {
  background: #fef3c7;
  color: #92400e;
}

.status.cancelled,
.inactive-pill {
  background: #fee2e2;
  color: #991b1b;
}

.status.processing {
  background: #dbeafe;
  color: #1d4ed8;
}

.status.completed {
  background: #ede9fe;
  color: #5b21b6;
}

.order-items {
  margin-top: 1rem;
  display: grid;
  gap: 0.6rem;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.item-row.total {
  border-top: 1px solid #e5e7eb;
  margin-top: 1rem;
  padding-top: 1rem;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
  margin-top: 1rem;
}

.actions button {
  background: #f3f4f6;
  color: #111827;
}

.products-layout {
  display: grid;
  grid-template-columns: 420px 1fr;
  gap: 1.2rem;
  align-items: start;
}

.product-form {
  display: grid;
  gap: 1rem;
  position: sticky;
  top: 1rem;
}

.two-cols {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.8rem;
}

.checks {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.checks label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.checks input {
  width: auto;
}

.form-actions {
  display: flex;
  gap: 0.7rem;
}

.product-list {
  display: grid;
  gap: 1rem;
}

.product-card {
  display: grid;
  gap: 1rem;
}

.product-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  align-items: center;
}

@media (max-width: 900px) {
  .dashboard {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: static;
  }

  .products-layout {
    grid-template-columns: 1fr;
  }

  .product-form {
    position: static;
  }

  .topbar {
    align-items: flex-start;
    flex-direction: column;
  }
}
.product-thumb {
  width: 100%;
  max-height: 220px;
  object-fit: cover;
  border-radius: 16px;
  border: 1px solid #e5e7eb;
  background: #f3f4f6;
}
.settings-layout {
  display: grid;
  grid-template-columns: minmax(320px, 520px) 1fr;
  gap: 1.2rem;
  align-items: start;
}

.settings-card,
.settings-preview {
  background: white;
  border-radius: 22px;
  padding: 1.25rem;
  box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
}

.settings-card {
  display: grid;
  gap: 1rem;
}

.banner-preview {
  width: 100%;
  height: 180px;
  object-fit: cover;
  border-radius: 18px;
  background: #f3f4f6;
  border: 1px solid #e5e7eb;
  margin-bottom: 1rem;
}

.logo-preview {
  width: 86px;
  height: 86px;
  object-fit: cover;
  border-radius: 999px;
  background: #f3f4f6;
  border: 4px solid white;
  box-shadow: 0 10px 25px rgba(15, 23, 42, 0.15);
  margin-top: -54px;
  margin-left: 1rem;
}

@media (max-width: 900px) {
  .settings-layout {
    grid-template-columns: 1fr;
  }
}
.admin-store-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  align-items: center;
}

.suspend-store-btn,
.reactivate-store-btn {
  border: 0;
  border-radius: 999px;
  padding: 10px 14px;
  font-weight: 800;
  cursor: pointer;
}

.suspend-store-btn {
  background: #fee2e2;
  color: #991b1b;
}

.reactivate-store-btn {
  background: #dcfce7;
  color: #166534;
}
.subscription-status.expired {
  background: #fee2e2;
  color: #991b1b;
}
.subscription-time {
  display: inline-flex;
  width: fit-content;
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 0.85rem;
  font-weight: 900;
}

.subscription-time.good {
  background: #dcfce7;
  color: #166534;
}

.subscription-time.warning {
  background: #fef3c7;
  color: #92400e;
}

.subscription-time.danger {
  background: #fee2e2;
  color: #991b1b;
}

.subscription-time.neutral {
  background: #e5e7eb;
  color: #374151;
}
.admin-summary-panel {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 24px;
  padding: 20px;
  margin-bottom: 20px;
}

.admin-summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 14px;
  margin-top: 16px;
}

.admin-summary-card {
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 16px;
  background: #f9fafb;
}

.admin-summary-card span {
  display: block;
  font-size: 0.78rem;
  font-weight: 800;
  color: #6b7280;
  margin-bottom: 8px;
}

.admin-summary-card strong {
  font-size: 1.35rem;
  font-weight: 950;
  color: #111827;
}

.admin-summary-card.good {
  background: #dcfce7;
  border-color: #bbf7d0;
}

.admin-summary-card.warning {
  background: #fef3c7;
  border-color: #fde68a;
}

.admin-summary-card.danger {
  background: #fee2e2;
  border-color: #fecaca;
}

.admin-summary-card.money {
  background: #eef2ff;
  border-color: #c7d2fe;
}
.subscription-warning-banner {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  border-radius: 22px;
  padding: 18px 20px;
  margin-bottom: 20px;
  border: 1px solid #fde68a;
  background: #fffbeb;
  color: #92400e;
}

.subscription-warning-banner h3 {
  margin: 0 0 5px;
  font-size: 1rem;
  font-weight: 950;
}

.subscription-warning-banner p {
  margin: 0;
  font-weight: 650;
}

.subscription-warning-banner strong {
  white-space: nowrap;
  border-radius: 999px;
  padding: 8px 12px;
  background: rgba(255, 255, 255, 0.7);
  font-weight: 950;
}

.subscription-warning-banner.danger {
  border-color: #fecaca;
  background: #fef2f2;
  color: #991b1b;
}

.subscription-warning-banner.warning {
  border-color: #fde68a;
  background: #fffbeb;
  color: #92400e;
}

@media (max-width: 700px) {
  .subscription-warning-banner {
    flex-direction: column;
    align-items: flex-start;
  }
}
.subscription-warning-actions {
  display: flex;
  gap: 10px;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.renew-subscription-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  padding: 9px 13px;
  background: #111827;
  color: #ffffff;
  text-decoration: none;
  font-weight: 900;
  font-size: 0.85rem;
  white-space: nowrap;
}

.renew-subscription-btn:hover {
  opacity: 0.9;
}

@media (max-width: 700px) {
  .subscription-warning-actions {
    justify-content: flex-start;
  }
}
.admin-store-filters {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin: 16px 0;
}

.admin-store-filters button {
  border: 1px solid #e5e7eb;
  background: #ffffff;
  color: #374151;
  border-radius: 999px;
  padding: 9px 13px;
  font-weight: 850;
  cursor: pointer;
}

.admin-store-filters button.active {
  background: #111827;
  color: #ffffff;
  border-color: #111827;
}
.admin-store-search {
  display: flex;
  gap: 10px;
  margin: 16px 0 10px;
}

.admin-store-search input {
  flex: 1;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 12px 15px;
  font-weight: 700;
  outline: none;
}

.admin-store-search input:focus {
  border-color: #111827;
}

.admin-store-search button {
  border: 0;
  border-radius: 999px;
  background: #111827;
  color: #ffffff;
  padding: 10px 14px;
  font-weight: 850;
  cursor: pointer;
}

@media (max-width: 700px) {
  .admin-store-search {
    flex-direction: column;
  }
}
.admin-header-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.admin-header-actions button {
  border: 0;
  border-radius: 999px;
  background: #111827;
  color: #ffffff;
  padding: 10px 14px;
  font-weight: 850;
  cursor: pointer;
}
.subscription-payment-filters {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin: 10px 0 16px;
}

.subscription-payment-filters button {
  border: 1px solid #e5e7eb;
  background: #ffffff;
  color: #374151;
  border-radius: 999px;
  padding: 9px 13px;
  font-weight: 850;
  cursor: pointer;
}

.subscription-payment-filters button.active {
  background: #111827;
  color: #ffffff;
  border-color: #111827;
}
.admin-plans-panel {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 24px;
  padding: 20px;
  margin-bottom: 20px;
}

.plan-settings-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
  margin-top: 16px;
}

.plan-settings-card {
  border: 1px solid #e5e7eb;
  border-radius: 20px;
  padding: 16px;
  background: #f9fafb;
}

.plan-settings-title {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
  margin-bottom: 14px;
}

.plan-settings-title span {
  display: block;
  color: #6b7280;
  font-size: 0.75rem;
  font-weight: 900;
  text-transform: uppercase;
}

.plan-settings-title h4 {
  margin: 4px 0 0;
  font-size: 1.15rem;
  font-weight: 950;
}

.plan-settings-title strong {
  border-radius: 999px;
  background: #eef2ff;
  color: #3730a3;
  padding: 7px 10px;
  font-size: 0.78rem;
  white-space: nowrap;
}

.plan-settings-card label {
  display: grid;
  gap: 6px;
  margin-bottom: 12px;
  font-weight: 850;
  color: #374151;
}

.plan-settings-card input[type="text"],
.plan-settings-card input[type="number"],
.plan-settings-card input:not([type]) {
  border: 1px solid #e5e7eb;
  border-radius: 14px;
  padding: 11px 12px;
  font-weight: 750;
  outline: none;
}

.plan-settings-card input:focus {
  border-color: #111827;
}

.plan-checkboxes {
  display: grid;
  gap: 8px;
  margin: 12px 0 16px;
}

.plan-checkboxes label {
  display: flex;
  align-items: center;
  gap: 9px;
  margin: 0;
}

.save-plan-btn {
  border: 0;
  border-radius: 999px;
  background: #111827;
  color: #ffffff;
  padding: 11px 14px;
  font-weight: 900;
  cursor: pointer;
}
.product-usage-card {
  border: 1px solid #e5e7eb;
  border-radius: 20px;
  padding: 16px;
  background: #f9fafb;
  margin-bottom: 18px;
}

.product-usage-head {
  display: flex;
  justify-content: space-between;
  gap: 14px;
  align-items: flex-start;
}

.product-usage-head span {
  display: block;
  font-size: 0.78rem;
  font-weight: 900;
  color: #6b7280;
  margin-bottom: 4px;
}

.product-usage-head h3 {
  margin: 0;
  font-size: 1.1rem;
  font-weight: 950;
  color: #111827;
}

.product-usage-head strong {
  border-radius: 999px;
  background: #eef2ff;
  color: #3730a3;
  padding: 8px 11px;
  font-size: 0.85rem;
  white-space: nowrap;
}

.product-usage-progress {
  height: 10px;
  background: #e5e7eb;
  border-radius: 999px;
  overflow: hidden;
  margin: 16px 0 12px;
}

.product-usage-progress-fill {
  height: 100%;
  border-radius: 999px;
  transition: width 0.2s ease;
}

.product-usage-progress-fill.good {
  background: #22c55e;
}

.product-usage-progress-fill.warning {
  background: #f59e0b;
}

.product-usage-progress-fill.danger {
  background: #ef4444;
}

.product-usage-meta {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  color: #4b5563;
  font-weight: 800;
  font-size: 0.9rem;
}

@media (max-width: 700px) {
  .product-usage-head,
  .product-usage-meta {
    flex-direction: column;
  }

  .product-usage-head strong {
    width: fit-content;
  }
}
.plan-feature-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 14px;
}

.plan-feature-chip {
  border-radius: 999px;
  padding: 7px 10px;
  font-size: 0.78rem;
  font-weight: 900;
}

.plan-feature-chip.enabled {
  background: #dcfce7;
  color: #166534;
}

.plan-feature-chip.disabled {
  background: #fee2e2;
  color: #991b1b;
}
.plan-restriction-note {
  border: 1px solid #fecaca;
  background: #fef2f2;
  color: #991b1b;
  border-radius: 14px;
  padding: 10px 12px;
  font-size: 0.88rem;
  font-weight: 850;
  margin: 8px 0 12px;
}
.admin-plan-change {
  display: grid;
  gap: 8px;
}

.admin-plan-change label {
  display: grid;
  gap: 6px;
}

.admin-plan-change span {
  color: #6b7280;
  font-size: 0.78rem;
  font-weight: 900;
}

.admin-plan-change select {
  border: 1px solid #e5e7eb;
  border-radius: 14px;
  padding: 10px 12px;
  font-weight: 850;
  background: #ffffff;
  outline: none;
}

.admin-plan-change select:focus {
  border-color: #111827;
}

.save-store-plan-btn {
  border: 0;
  border-radius: 999px;
  background: #111827;
  color: #ffffff;
  padding: 10px 12px;
  font-weight: 900;
  cursor: pointer;
}

.save-store-plan-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}
.product-limit-warning {
  border: 1px solid #fed7aa;
  background: #fff7ed;
  color: #9a3412;
  border-radius: 18px;
  padding: 14px;
  margin-bottom: 14px;
}

.product-limit-warning strong {
  display: block;
  font-weight: 950;
  margin-bottom: 5px;
}

.product-limit-warning p {
  margin: 0;
  font-weight: 750;
  line-height: 1.5;
}
.premium-login-page {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 28px;
  background:
    radial-gradient(circle at top left, rgba(17, 24, 39, 0.18), transparent 34%),
    radial-gradient(circle at bottom right, rgba(37, 99, 235, 0.16), transparent 34%),
    linear-gradient(135deg, #f8fafc 0%, #eef2ff 45%, #f9fafb 100%);
}

.login-hero-card {
  width: min(1120px, 100%);
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 22px;
  align-items: stretch;
}

.login-brand-panel,
.premium-login-card {
  border: 1px solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 30px 80px rgba(15, 23, 42, 0.16);
  backdrop-filter: blur(18px);
}

.login-brand-panel {
  border-radius: 34px;
  padding: 42px;
  color: #ffffff;
  background:
    linear-gradient(135deg, rgba(17, 24, 39, 0.96), rgba(30, 41, 59, 0.92)),
    radial-gradient(circle at top right, rgba(96, 165, 250, 0.35), transparent 32%);
  overflow: hidden;
  position: relative;
}

.login-brand-panel::after {
  content: "";
  position: absolute;
  width: 230px;
  height: 230px;
  border-radius: 999px;
  right: -80px;
  bottom: -90px;
  background: rgba(255, 255, 255, 0.08);
}

.login-brand-badge {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  display: grid;
  place-items: center;
  font-weight: 950;
  letter-spacing: -0.04em;
  color: #111827;
  background: #ffffff;
  box-shadow: 0 18px 38px rgba(0, 0, 0, 0.2);
}

.login-eyebrow {
  margin: 34px 0 10px;
  color: #bfdbfe;
  font-size: 0.8rem;
  font-weight: 950;
  text-transform: uppercase;
  letter-spacing: 0.14em;
}

.login-brand-panel h1 {
  margin: 0;
  max-width: 560px;
  font-size: clamp(2.3rem, 5vw, 4.8rem);
  line-height: 0.95;
  letter-spacing: -0.08em;
}

.login-brand-panel p {
  max-width: 520px;
  margin: 18px 0 0;
  color: #dbeafe;
  font-weight: 700;
  line-height: 1.65;
}

.login-feature-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 34px;
}

.login-feature-list span {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.09);
  color: #ffffff;
  border-radius: 999px;
  padding: 10px 13px;
  font-size: 0.8rem;
  font-weight: 900;
}

.premium-login-card {
  border-radius: 34px;
  padding: 34px;
  background: rgba(255, 255, 255, 0.9);
}

.login-card-head {
  margin-bottom: 22px;
}

.login-mini-badge {
  display: inline-flex;
  border-radius: 999px;
  padding: 7px 11px;
  background: #ecfdf5;
  color: #047857;
  font-size: 0.78rem;
  font-weight: 950;
}

